# Telegram Bot Token (obtain from @BotFather)
TELEGRAM_BOT_TOKEN=

# Path to the Google OAuth client secrets file (download from Google Cloud Console)
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json

# Path where the YouTube OAuth token will be saved (auto-generated on first --auth run)
GOOGLE_TOKEN_FILE=tokens/youtube_token.json

# Directory for temporary video downloads
DOWNLOAD_DIR=downloads

# Maximum allowed file size in bytes (default: 1.6 GB)
MAX_FILE_SIZE=1717986918

# Download progress update interval in bytes (default: 10 MB)
DOWNLOAD_PROGRESS_CHUNK=10485760

# Files larger than this (bytes) are streamed directly from the Telegram CDN (default: 20 MB)
TELEGRAM_DIRECT_DOWNLOAD_THRESHOLD=20971520
