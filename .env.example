# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# Google OAuth 客户端配置文件路径（从 Google Cloud Console 下载）
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json

# YouTube OAuth Token 保存路径（首次 --auth 授权后自动生成）
GOOGLE_TOKEN_FILE=tokens/youtube_token.json

# 临时视频下载目录
DOWNLOAD_DIR=downloads

# 最大允许文件大小（字节），默认 1.6GB
MAX_FILE_SIZE=1717986918

# 下载进度更新间隔（字节），默认 10MB
DOWNLOAD_PROGRESS_CHUNK=10485760

# 超过此大小（字节）改用 CDN 直接下载，默认 20MB
TELEGRAM_DIRECT_DOWNLOAD_THRESHOLD=20971520
